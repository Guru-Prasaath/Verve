# ---- CRM service (server.ts) ----
PORT=4000
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Where the CRM reaches the (separate) Channel Service.
CHANNEL_SERVICE_URL=http://127.0.0.1:4100

# Optional — enables real AI planning (Claude). Without it, /agent/plan
# transparently falls back to the deterministic keyword compiler.
# ANTHROPIC_API_KEY=sk-ant-...

# ---- Channel service (channelService.ts) ----
# Its own port, and where it posts delivery receipts back to the CRM.
CHANNEL_PORT=4100
CRM_URL=http://127.0.0.1:4000
