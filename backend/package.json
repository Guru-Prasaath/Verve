{
  "name": "verve-backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start:channel": "node dist/channelService.js",
    "start:all": "concurrently -n CRM,CHANNEL -c blue,magenta \"npm:start\" \"npm:start:channel\"",
    "dev": "nodemon --watch src -e ts --exec ts-node src/server.ts",
    "dev:channel": "nodemon --watch src -e ts --exec ts-node src/channelService.ts",
    "dev:all": "concurrently -n CRM,CHANNEL -c blue,magenta \"npm:dev\" \"npm:dev:channel\"",
    "seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@supabase/supabase-js": "^2.43.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
